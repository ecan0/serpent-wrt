<!--
  Wazuh decoder for serpent-wrt NDJSON events received via syslog.
  The syslog MSG field contains the full JSON object.

  Install: copy to /var/ossec/etc/decoders/ and restart Wazuh.
-->
<decoder name="serpent-wrt">
  <program_name>serpent-wrt</program_name>
  <prematch>{"time":</prematch>
</decoder>

<decoder name="serpent-wrt-json">
  <parent>serpent-wrt</parent>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
